# Poker Game Backend Environment Variables

# --- SECURITY ---
# JWT Secret Key: Must be a Base64-encoded string representing at least 512 bits (64 bytes) of key material.
# Example 512-bit key: AAAAAAAAAAAAAAAAAAAAABAAbbbbbbbbbbbbccccccccccccccd4444444444444444444444444
JWT_SECRET=AAAAAAAAAAAAAAAAAAAAABAAbbbbbbbbbbbbccccccccccccccd4444444444444444444444444

# JWT Expiration in milliseconds (Default: 14400000 / 4 hours)
JWT_EXPIRATION_MILLIS=14400000

# --- INFRASTRUCTURE ---
# Server Port (Default: 8080)
SERVER_PORT=8080

# --- CORS & PROXY ---
# Comma-separated list of allowed origins for CORS (Default: http://localhost:5173,https://*.ngrok-free.app)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://production-ui.com

# Set to true if the app is running behind a proxy (like Nginx or Cloudflare) to correctly resolve client IPs (Default: false)
TRUST_PROXY=false
